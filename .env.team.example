# AgentSquad credentials — v1.4
# Copy this file: cp .env.team.example ~/.agent-team/.env.team
# Then: chmod 600 ~/.agent-team/.env.team
# Get your key at: aistudio.google.com → Get API Key
#
# NEVER commit ~/.agent-team/.env.team to git.
# This .example file is safe to commit — it contains no real keys.

GEMINI_API_KEY=your_key_here

# ── Optional: per-agent key overrides ────────────────────────────────────────
# Uncomment ONLY if using separate Google accounts per agent (independent quota).
# Unset keys fall back to GEMINI_API_KEY automatically.
#
# GEMINI_KEY_BACKEND=your_key_here
# GEMINI_KEY_FRONTEND=your_key_here
# GEMINI_KEY_QA=your_key_here
# GEMINI_KEY_DEVOPS=your_key_here
# GEMINI_KEY_CONSULTANT=your_key_here
# GEMINI_KEY_RESERVE_1=your_key_here   # fallback on 429 (auto-used by gemini-call.sh)
# GEMINI_KEY_GEMMA=your_key_here       # fallback key for Gemma tier (14,400 RPD)

# ── Optional: model overrides ────────────────────────────────────────────────
# Default: gemini-3-flash (20 RPD free tier). Override here per agent.
# GEMINI_MODEL is read by gemini-cli — do NOT use the -m CLI flag (broken in 0.32.1+).
#
# Gemini tier (20 RPD free each):
# BACKEND_MODEL=gemini-3-flash
# FRONTEND_MODEL=gemini-3-flash
# QA_MODEL=gemini-3-flash
# DEVOPS_MODEL=gemini-3-flash
# CONSULT_MODEL=gemini-3-flash
#
# Gemma tier — 14,400 RPD free, near-Flash quality for most tasks:
# GEMMA_MODEL=gemma-3-27b-it           # default Gemma model (make *-lite targets)
# GEMINI_MODEL_FALLBACK=gemma-3-27b-it # auto-used by gemini-call.sh on quota exhaustion
#
# Available Gemma models (all 14,400 RPD free):
#   gemma-3-1b-it   — ultra-fast, health checks only
#   gemma-3-4b-it   — simple boilerplate, light rewrites
#   gemma-3-12b-it  — standard agent tasks on budget
#   gemma-3-27b-it  — near-Flash quality, max free quota (recommended)
