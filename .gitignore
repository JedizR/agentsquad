# AgentSquad — .gitignore

# Credentials — NEVER commit
.env*
!.env.team.example
!.env.example

# Gemini agent output — all LLM output goes here, never commit
agent-output/
!agent-output/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Logs
*.log
logs/

# Node
node_modules/
npm-debug.log*

# Editors
.idea/
.vscode/
*.swp
*.swo
*~

# Temp files
*.tmp
*.temp
/tmp/
